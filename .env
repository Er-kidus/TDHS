# Local developer overrides
# Your machine already uses 5432, so run Tenadam Postgres on 5433.
POSTGRES_PORT=5433

# API gateway JWT signing secret
JWT_SECRET=dev-jwt-secret

# Cloud LiveKit credentials
LIVEKIT_API_KEY=REDACTED_FOR_PUSH
LIVEKIT_API_SECRET=REDACTED_FOR_PUSH

# Internal URL used by services inside Docker network (do not change)
LIVEKIT_URL=wss://tdhs-a2li0kk2.livekit.cloud

# ── Cross-device / ngrok setup ─────────────────────────────────────────────
# When using ngrok, set LIVEKIT_NODE_IP to your machine's PUBLIC IP address.
# Run: curl -s https://api.ipify.org to get it.
# Then restart only the livekit container: docker compose restart livekit
#
# LIVEKIT_NODE_IP is the IP LiveKit advertises for ICE/WebRTC media (UDP 7881).
# LIVEKIT_PUBLIC_URL is the URL returned to browser clients for the signaling WebSocket.
# When ngrok is active, set LIVEKIT_PUBLIC_URL to your ngrok https URL,
# e.g. LIVEKIT_PUBLIC_URL=REDACTED_FOR_PUSH
# (The portals will automatically route it through /livekit/ proxy path)
# ───────────────────────────────────────────────────────────────────────────

# LAN / public IP for LiveKit ICE candidate advertising
LIVEKIT_NODE_IP=REDACTED_FOR_PUSH

# Public URL returned to browser clients for the LiveKit signaling WebSocket.
# On LAN: ws://10.108.110.113:7880
# With ngrok: https://your-subdomain.ngrok-free.app
LIVEKIT_PUBLIC_URL=REDACTED_FOR_PUSH

# Gemini AI — model used for session summaries
GEMINI_API_KEY=REDACTED_FOR_PUSH
GEMINI_MODEL=gemini-2.5-flash

# Groq AI keys
GROQ_API_KEY=REDACTED_FOR_PUSH

