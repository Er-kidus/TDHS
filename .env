# Local developer overrides
# Your machine already uses 5432, so run Tenadam Postgres on 5433.
POSTGRES_PORT=5433

# API gateway JWT signing secret
JWT_SECRET=dev-jwt-secret

# Self-hosted LiveKit credentials
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecretdevsecretdevsecretdev12

# Internal URL used by services inside Docker network
LIVEKIT_URL=ws://livekit:7880

# Public URL returned to patient/org clients on LAN
LIVEKIT_PUBLIC_URL=ws://10.144.55.60:7880

# Local environment default: do not advertise external IP candidates automatically
LIVEKIT_NODE_IP=10.144.55.60
