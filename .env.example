# ── Database ─────────────────────────────────
POSTGRES_USER=tenadam
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tenadam
DATABASE_URL=postgres://tenadam:change_me_in_production@localhost:5432/tenadam?sslmode=disable

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── Auth ──────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRY=3600

# ── Services ──────────────────────────────────
PORT=:8080
AUTH_SERVICE_URL=http://localhost:8001
USER_SERVICE_URL=http://localhost:8002
PATIENT_SERVICE_URL=http://localhost:8010

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AI Services ───────────────────────────────
AI_TRIAGE_SERVICE_URL=http://localhost:8100
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Telemedicine ──────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
DAILY_CO_API_KEY=
# Local LiveKit signaling URL for local-only development fallback
LIVEKIT_URL=ws://127.0.0.1:7880
# Public secure signaling URL used by clients over HTTPS.
# Option 1 (recommended): your LiveKit Cloud URL, e.g. wss://your-project.livekit.cloud
LIVEKIT_PUBLIC_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional local-proxy mode (only needed if you explicitly proxy /livekit through patient-portal)
# LIVEKIT_PROXY_TARGET=http://127.0.0.1:7880

# Optional same-LAN portal origin shown as "Local network room link" in telemedicine UIs.
# Example: http://10.144.55.60:3000
NEXT_PUBLIC_LOCAL_NETWORK_ORIGIN=

# ── Notifications ─────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
