# Database Configuration
DATABASE_URL=postgres://username:password@localhost:5432/pharmacy_db?sslmode=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Server Configuration
PORT=8080
ENVIRONMENT=development

# EMR Integration Configuration
EMR_API_KEY=your-emr-api-key
EMR_ENDPOINT=https://api.emr-system.com

# File Storage Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=pharmacy-documents

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
